// storage.rules
// Deploy with: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /rewards/{filename} {
      // Anyone can read reward files (protected by password in app logic)
      allow read: if true;
      // Anyone can upload reward files (images/videos) up to 50MB
      allow write: if request.resource.size < 50 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*')
            || request.resource.contentType.matches('video/.*'));
    }
  }
}
